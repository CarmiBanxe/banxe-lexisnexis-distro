# Collective LexisNexis - Configuration
# Copy this file to .env and fill in your values

# === AI Provider ===
# Options: ollama (local, free), openai, anthropic
AI_PROVIDER=ollama

# For cloud AI (optional, leave empty for local Ollama)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Ollama Settings ===
OLLAMA_HOST=http://ollama:11434
OLLAMA_PORT=11434

# === Service Ports ===
UI_PORT=3000
ORCHESTRATOR_PORT=8000
KNOWLEDGE_PORT=8001
COMPLIANCE_PORT=8002
LEGAL_PORT=8003
MIROFISH_PORT=8004

# === Compliance Settings ===
COMPLIANCE_STRICT=true

# === Legal Jurisdictions ===
# Comma-separated: FR (France), IL (Israel), RU (Russia), UK, US
JURISDICTIONS=FR,IL,RU

# === License Key ===
# Contact admin for your license key
LICENSE_KEY=
